<!--
    Auto-imported by NuGet when this AOT-cross pack is restored. Tokens are
    substituted at pack time by the csproj (_UnoGenerateAotCrossProps target):
      __RID__       → pack's host RID (e.g. linux-x64)
      __RID_USCORE__→ same with hyphens replaced by underscores (linux_x64)
                       so it can be embedded in an MSBuild property name
      __EXE__       → binary name (mono-aot-cross or mono-aot-cross.exe)

    The generated file is shipped at
      buildTransitive/uno.netcore.app.runtime.aot.<RID>.cross.browser-wasm.props
    inside each AOT-cross pack; the file name matches the lowercased
    PackageId so NuGet's auto-import picks it up automatically.

    Why per-RID property names and not a Condition on
    $(NETCoreSdkPortableRuntimeIdentifier)?
      NuGet auto-imports buildTransitive .props very early — before the
      .NET SDK has populated $(NETCoreSdkPortableRuntimeIdentifier). A
      Condition checking that property would always be false at import
      time. Instead, each cross pack contributes a uniquely-named property
      (_UnoMonoAotCrossCompilerPath_<rid>) that the main override pack's
      .targets reads in a Target running after the SDK has set the RID
      property.

    Layout probing: the Linux/macOS CI jobs flatten cross/browser-wasm/*
    into nuget/tools/, so the binary lands at tools/__EXE__. The Windows
    CI job moves the whole cross/ directory, so the binary lands at
    tools/cross/browser-wasm/__EXE__. We expose both candidates; the
    consuming .targets picks whichever exists.
-->
<Project>
  <PropertyGroup>
    <_UnoMonoAotCrossCompilerPath_FlatCandidate___RID_USCORE__>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildThisFileDirectory)', '..', 'tools', '__EXE__'))))</_UnoMonoAotCrossCompilerPath_FlatCandidate___RID_USCORE__>
    <_UnoMonoAotCrossCompilerPath_NestedCandidate___RID_USCORE__>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildThisFileDirectory)', '..', 'tools', 'cross', 'browser-wasm', '__EXE__'))))</_UnoMonoAotCrossCompilerPath_NestedCandidate___RID_USCORE__>
  </PropertyGroup>
</Project>
