+        [ConditionalFact(typeof(ApplyUpdateUtil), nameof(ApplyUpdateUtil.IsSupported))]
+        public static void TestAddNewTypeWithEvents()
+        {
+            // Regression test: the ENC_FUNC_ADD_EVENT handler used assignment (=) instead
+            // of comparison (==) in its g_assert, silently corrupting token_table to
+            // MONO_TABLE_EVENTMAP.  This caused the subsequent switch(token_table) to
+            // route to the wrong case, leading to out-of-bounds row access and a crash.
+            // Generation 1 adds a type with events (exercising ENC_FUNC_ADD_EVENT).
+            // Generation 2 modifies the same type, re-emitting event tokens.
+            ApplyUpdateUtil.TestCase(static () =>
+            {
+                const string ns = "System.Reflection.Metadata.ApplyUpdate.Test.AddNewTypeWithEvents";
+                var assm = typeof(System.Reflection.Metadata.ApplyUpdate.Test.AddNewTypeWithEvents.ExistingClass).Assembly;
+
+                // Baseline: only ExistingClass
+                var existingTy = assm.GetType($"{ns}.ExistingClass");
+                Assert.NotNull(existingTy);
+                Assert.Null(assm.GetType($"{ns}.NewClassWithEvents"));
+
+                // Generation 1: adds NewClassWithEvents with events
+                ApplyUpdateUtil.ApplyUpdate(assm);
+
+                var newTy = assm.GetType($"{ns}.NewClassWithEvents");
+                Assert.NotNull(newTy);
+
+                // Verify events exist
+                var nameChangedEvt = newTy.GetEvent("NameChanged");
+                Assert.NotNull(nameChangedEvt);
+                Assert.NotNull(nameChangedEvt.GetAddMethod());
+                Assert.NotNull(nameChangedEvt.GetRemoveMethod());
+
+                var closedEvt = newTy.GetEvent("Closed");
+                Assert.NotNull(closedEvt);
+                Assert.NotNull(closedEvt.GetAddMethod());
+                Assert.NotNull(closedEvt.GetRemoveMethod());
+
+                // Subscribe and fire to verify events work
+                var obj = Activator.CreateInstance(newTy);
+                string received = null;
+                nameChangedEvt.AddEventHandler(obj, new EventHandler<string>((s, e) => received = e));
+                newTy.GetMethod("OnNameChanged").Invoke(obj, new object[] { "test" });
+                Assert.Equal("test", received);
+
+                // Generation 2: modifies the same type (adds a method)
+                // This re-emits EVENTMAP/EVENT tokens — before the fix, the corrupted
+                // token_table caused a runtime crash here.
+                ApplyUpdateUtil.ApplyUpdate(assm);
+
+                // Verify events still work after gen 2
+                var obj2 = Activator.CreateInstance(newTy);
+                string received2 = null;
+                nameChangedEvt.AddEventHandler(obj2, new EventHandler<string>((s, e) => received2 = e));
+                newTy.GetMethod("OnNameChanged").Invoke(obj2, new object[] { "after-update" });
+                Assert.Equal("after-update", received2);
+
+                // Verify the new method from gen 2
+                var getStatus = newTy.GetMethod("GetStatus");
+                Assert.NotNull(getStatus);
+                Assert.Equal("active", getStatus.Invoke(obj2, null));
+            });
+        }
+
