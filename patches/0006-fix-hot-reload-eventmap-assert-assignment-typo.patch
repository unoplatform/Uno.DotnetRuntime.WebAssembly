+/// <summary>
+/// Generation 2: Same type as v1, but with a new method added.
+/// This re-emits EVENTMAP, EVENT, METHODSEMANTICS, and FIELD entries
+/// where the ENC_FUNC_ADD_EVENT handler assertion previously corrupted
+/// token_table with assignment (=) instead of comparison (==).
+/// </summary>
+public class NewClassWithEvents
+{
+    public event EventHandler<string> NameChanged;
+    public event EventHandler Closed;
+
+    public void OnNameChanged(string name) => NameChanged?.Invoke(this, name);
+    public void OnClosed() => Closed?.Invoke(this, EventArgs.Empty);
+
+    public string GetStatus() => "active";
+}
