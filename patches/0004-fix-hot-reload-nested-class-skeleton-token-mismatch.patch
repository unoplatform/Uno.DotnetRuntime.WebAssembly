+// Licensed to the .NET Foundation under one or more agreements.
+// The .NET Foundation licenses this file to you under the MIT license.
+using System;
+
+namespace System.Reflection.Metadata.ApplyUpdate.Test
+{
+    public class AddNewTypeWithNestedClass
+    {
+        public string TestMethod()
+        {
+            var container = new NewContainer();
+            return container.GetValue();
+        }
+    }
+
+    public class NewContainer
+    {
+        public int Id { get; set; } = 42;
+        public string Name { get; set; } = "Container";
+
+        public string GetValue()
+        {
+            var inner = new InnerHelper();
+            var detail = new InnerDetail();
+            return Name + ":" + inner.Compute(Id) + ":" + detail.Tag;
+        }
+
+        public class InnerHelper
+        {
+            public int Factor { get; set; } = 10;
+            public string Compute(int value) => (value * Factor).ToString();
+        }
+
+        public class InnerDetail
+        {
+            public string Tag { get; set; } = "detail-v1";
+        }
+    }
+}
