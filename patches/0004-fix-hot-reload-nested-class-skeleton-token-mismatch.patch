+        [ConditionalFact(typeof(ApplyUpdateUtil), nameof(ApplyUpdateUtil.IsSupported))]
+        public static void TestAddNewTypeWithNestedClass()
+        {
+            // Regression test: adding a brand-new enclosing type WITH nested classes
+            // in a single delta.  Before the fix, pass2_context_is_skeleton compared
+            // bare NestedClass RIDs against full tokens stored in skeletons — the
+            // comparison always failed, causing premature class creation for skeleton
+            // types and crashing in mono_metadata_decode_row_raw.
+            ApplyUpdateUtil.TestCase(static () =>
+            {
+                var assm = typeof(System.Reflection.Metadata.ApplyUpdate.Test.AddNewTypeWithNestedClass).Assembly;
+
+                var x = new System.Reflection.Metadata.ApplyUpdate.Test.AddNewTypeWithNestedClass();
+                Assert.Equal("baseline", x.TestMethod());
+
+                // Gen 1: adds NewContainer with two nested classes (InnerHelper, InnerDetail)
+                ApplyUpdateUtil.ApplyUpdate(assm);
+
+                var result = x.TestMethod();
+                Assert.Equal("Container:420:detail-v1", result);
+
+                var containerTy = assm.GetType("System.Reflection.Metadata.ApplyUpdate.Test.NewContainer");
+                Assert.NotNull(containerTy);
+                Assert.NotNull(containerTy.GetNestedType("InnerHelper"));
+                Assert.NotNull(containerTy.GetNestedType("InnerDetail"));
+
+                // Gen 2: modifies the same types (is_addition=false for these tokens)
+                ApplyUpdateUtil.ApplyUpdate(assm);
+
+                result = x.TestMethod();
+                Assert.Equal("Updated:495:detail-v2", result);
+            });
+        }
+
