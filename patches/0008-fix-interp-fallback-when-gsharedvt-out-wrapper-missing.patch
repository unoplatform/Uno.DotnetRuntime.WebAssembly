From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jerome Laban <noreply@platform.uno>
Date: Wed, 13 May 2026 00:00:00 +0000
Subject: [PATCH] fix: interpreter fallback when gsharedvt_out_sig wrapper
 is missing in aot-only mode

The AOT-side widening in patch 0007 closes the gsharedvt_out_sig
coverage gap for signatures observed during compilation
(cfg->signatures and cfg->interp_in_signatures). It cannot help
signatures the AOT compiler never observed at compile time --
signatures the interpreter synthesises at runtime from method
metadata.

A concrete instance from a WASM worker hosting Roslyn (.NET 10,
LLVMOnly+Interp):

  [MONO] * Assertion at .../mono/mini/interp/interp.c,
    function: init_jit_call_info,
    Attempting to JIT compile method '(wrapper other) void object:
      gsharedvt_out_sig (intptr,
        Microsoft.CodeAnalysis.CompoundUseSiteInfo`1<object>&,
        object&, object&, intptr)'
    while running in aot-only mode.

Symbol scan of the AOT-built worker wasm confirms neither IN nor OUT
wrappers exist for the failing 5-param shape; nine IN wrappers for
adjacent CompoundUseSiteInfo<object>-bearing signatures are present
but all of them have different param counts / hasthis.

This patch adds a runtime-side fallback. When
mono_jit_compile_method_jit_only fails on the OUT wrapper,
init_jit_call_info flags cinfo->interp_fallback. do_jit_call then
bypasses the missing wrapper and runs rmethod->method through the
interpreter via mono_interp_exec_method.

Why this works without arg translation: the interpreter compiler
already laid out the args at `sp` in stackval form for the target
method, since the same call site could just as well have been
emitted as MINT_CALL (which consumes args from the same locals
offset). MINT_JIT_CALL is purely an optimisation that hands the
args to compiled AOT code via the gsharedvt_out_sig wrapper; when
that wrapper is unavailable we route to the same interp path
MINT_CALL would have used, just from inside do_jit_call.

A prior attempt at this fallback spliced an
`interp_create_method_pointer_llvmonly`-produced interp entry into
cinfo via the wrapped jit_call_cb path. That failed at runtime with
a WASM call_indirect signature mismatch: the IN wrapper for the OUT
wrapper's signature expects param_count+1 args (it appends a ftndesc
of its own), while jit_call_cb supplies only param_count args plus
extra_arg -- off by one. The current patch sidesteps the calling
convention entirely by skipping jit_call_cb on the fallback path.

A g_warning is logged on each fallback so AOT-side coverage
regressions do not silently turn into slow interpreter executions.

Trade-offs:
- Slower than calling the AOT-compiled method through a native
  gsharedvt_out_sig wrapper. Correct, and avoids a g_assert-driven
  runtime exit.
- The target method runs through the interpreter for this call
  site, not its AOT code path. Reachable from any call site whose
  signature the AOT compiler never observed; the warning makes
  regressions visible.

Fixes: downstream WASM worker AOT path (LLVMOnly+Interp).
---
 src/mono/mono/mini/interp/interp.c | 100 +++++++++++++++++++++++++++++++++++-
 1 file changed, 99 insertions(+), 1 deletion(-)

diff --git a/src/mono/mono/mini/interp/interp.c b/src/mono/mono/mini/interp/interp.c
index 0a12875dcce..bb04bc1ec6a 100644
--- a/src/mono/mono/mini/interp/interp.c
+++ b/src/mono/mono/mini/interp/interp.c
@@ -2690,6 +2690,13 @@ struct _JitCallInfo {
 	gint32 res_size;
 	int ret_mt;
 	gboolean no_wrapper;
+	/*
+	 * Set in LLVMOnly+Interp aot-only mode when the gsharedvt_out_sig wrapper
+	 * for sig is not in the AOT image and cannot be JITted. do_jit_call then
+	 * routes the call through the interpreter on rmethod->method directly,
+	 * bypassing the missing native wrapper. See init_jit_call_info / do_jit_call.
+	 */
+	gboolean interp_fallback;
 #if HOST_BROWSER
 	int hit_count;
 	WasmJitCallThunk jiterp_thunk;
@@ -2734,7 +2741,31 @@ init_jit_call_info (InterpMethod *rmethod, MonoError *error)
 	if (need_wrapper) {
 		MonoMethod *wrapper = mini_get_gsharedvt_out_sig_wrapper (sig);
 		jit_wrapper = mono_jit_compile_method_jit_only (wrapper, error);
-		mono_error_assert_ok (error);
+		if (!is_ok (error)) {
+			/*
+			 * The gsharedvt_out_sig wrapper for this signature is not in the
+			 * AOT image and we cannot JIT it in aot-only mode (LLVMOnly+Interp
+			 * on WASM). The AOT compiler never observed this signature at
+			 * compile time (cfg->signatures and cfg->interp_in_signatures of
+			 * every compiled method); it was synthesised by the interpreter
+			 * at runtime from method metadata. No widening of the AOT-side
+			 * emission paths can cover it.
+			 *
+			 * Fall back to executing the target method's IL through the
+			 * interpreter. do_jit_call detects this flag and bypasses the
+			 * missing native wrapper, calling mono_interp_exec_method
+			 * directly. The args at sp are already in interpreter stackval
+			 * form for the target method, so no arg translation is needed.
+			 *
+			 * Log a warning on each fallback so AOT-side coverage regressions
+			 * do not silently turn into slow interpreter executions.
+			 */
+			mono_error_cleanup (error);
+			error_init (error);
+			cinfo->interp_fallback = TRUE;
+			g_warning ("init_jit_call_info: gsharedvt_out_sig wrapper missing in AOT image for '%s'; falling back to interpreter.",
+				mono_method_full_name (method, TRUE));
+		}
 	}
 
 	if (mono_llvm_only) {
@@ -2794,6 +2825,16 @@ mono_jiterp_register_jit_call_thunk (void *cinfo, WasmJitCallThunk thunk) {
 }
 #endif
 
+/* Forward declaration: defined further down in this file. Needed by the
+ * interpreter-fallback path in do_jit_call when a gsharedvt_out_sig wrapper
+ * is missing from the AOT image and we route the call through interp. */
+static MONO_ALWAYS_INLINE gboolean
+method_entry (ThreadContext *context, InterpFrame *frame,
+#if DEBUG_INTERP
+	int *out_tracing,
+#endif
+	MonoException **out_ex);
+
 static MONO_NEVER_INLINE void
 do_jit_call (ThreadContext *context, stackval *ret_sp, stackval *sp, InterpFrame *frame, InterpMethod *rmethod, MonoError *error)
 {
@@ -2814,6 +2855,56 @@ do_jit_call (ThreadContext *context, stackval *ret_sp, stackval *sp, InterpFrame
 
 	cinfo = (JitCallInfo*)rmethod->jit_call_info;
 
+	if (G_UNLIKELY (cinfo->interp_fallback)) {
+		/*
+		 * The gsharedvt_out_sig wrapper this call site needs is not present
+		 * in the AOT image (see init_jit_call_info). Run rmethod->method
+		 * through the interpreter directly. The args at sp are already laid
+		 * out in stackval form for this method (the interpreter compiler
+		 * placed them there for this call), so we can build a child frame
+		 * pointing at the same stack region and execute it.
+		 */
+		InterpFrame child_frame;
+		memset (&child_frame, 0, sizeof (child_frame));
+		reinit_frame (&child_frame, frame, rmethod, ret_sp, sp);
+
+		guchar *saved_stack_pointer = context->stack_pointer;
+
+		MonoException *call_ex;
+		if (method_entry (context, &child_frame,
+#if DEBUG_INTERP
+			NULL,
+#endif
+			&call_ex)) {
+			if (call_ex) {
+				mono_error_set_exception_instance (error, call_ex);
+				context->stack_pointer = saved_stack_pointer;
+				return;
+			}
+		}
+
+		context->stack_pointer = (guchar*)child_frame.stack + rmethod->alloca_size;
+		if (G_UNLIKELY (context->stack_pointer >= context->stack_end)) {
+			context->stack_end = context->stack_real_end;
+			mono_error_set_exception_instance (error, mono_domain_get ()->stack_overflow_ex);
+			context->stack_pointer = saved_stack_pointer;
+			return;
+		}
+		mono_compiler_barrier ();
+
+		MONO_ENTER_GC_UNSAFE;
+		mono_interp_exec_method (&child_frame, context, NULL);
+		MONO_EXIT_GC_UNSAFE;
+
+		context->stack_pointer = saved_stack_pointer;
+
+		if (context->has_resume_state) {
+			if (mono_aot_mode == MONO_AOT_MODE_LLVMONLY_INTERP)
+				mono_llvm_start_native_unwind ();
+		}
+		return;
+	}
+
 #if JITERPRETER_ENABLE_JIT_CALL_TRAMPOLINES
 	// The jiterpreter will compile a unique thunk for each do_jit_call call site if it is hot
 	//  enough to justify it. At that point we can invoke the thunk to efficiently do most of
--
2.43.0
